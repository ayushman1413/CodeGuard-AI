{
  "name": "codeguard-ai-studio",
  "displayName": "CodeGuard AI STUDIO",
"description": "Your AI-powered code review and security assistant. Analyze code changes, detect vulnerabilities, explain risks, and get intelligent fix suggestions directly inside Visual Studio Code." , 
  "version": "1.0.1",
"publisher": "Ayushman",
  "license": "MIT",
  "homepage": "https://github.com/ayushman1413/Codeguard-AI#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ayushman1413/Codeguard-AI.git"
  },
  "bugs": {
    "url": "https://github.com/ayushman1413/Codeguard-AI/issues"
  },
  "icon": "assets/logo.png",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "keywords": [
  "ai",
  "security",
  "code-review",
  "vulnerability",
  "static-analysis",
  "developer-tools",
  "code-quality",
  "bug-detection",
  "secure-coding",
  "codeguard"
],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeguard-ai.openPanel",
        "title": "Codeguard AI: Open Dashboard"
      },
      {
        "command": "codeguard-ai.runAnalysis",
        "title": "Codeguard AI: Run Analysis on Current File"
      },
      {
        "command": "codeguard-ai.clearHistory",
        "title": "Codeguard AI: Clear Save History"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeguard-ai-sidebar",
          "title": "Codeguard AI",
          "icon": "media/shield.svg"
        }
      ]
    },
    "views": {
      "codeguard-ai-sidebar": [
        {
          "type": "webview",
          "id": "codeguard-ai.sidebarView",
          "name": "Codeguard AI"
        }
      ]
    },
    "configuration": {
      "title": "Codeguard AI",
      "properties": {
        "codeguardAI.sambanovaApiKey": {
          "type": "string",
          "default": "",
          "description": "SambaNova API key for AI-powered analysis. Leave empty to use rule-based analysis only.",
          "order": 1
        },
        "codeguardAI.sambanovaModel": {
          "type": "string",
          "default": "DeepSeek-V3",
          "description": "SambaNova model to use for analysis.",
          "order": 2
        },
        "codeguardAI.autoAnalyzeOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically run analysis when a file is saved.",
          "order": 3
        },
        "codeguardAI.historyRetentionDays": {
          "type": "number",
          "default": 7,
          "description": "Number of days to retain file save history.",
          "order": 4
        },
        "codeguardAI.enableTerminalTracking": {
          "type": "boolean",
          "default": true,
          "description": "Track terminal commands and their file system effects.",
          "order": 5
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint extension.js src/**/*.js",
    "pretest": "npm run lint",
    "test": "node -e \"console.log('No extension tests configured')\"",
    "build:webview": "cd webview && npm run build"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.93.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3"
  },
  "dependencies": {
    "fs-extra": "^11.3.4"
  }
}
